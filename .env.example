# API container -> Postgres connection (used by docker-compose.yml)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=game-platform-db
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass

# Optional: if you also run pgAdmin (not used by this API container)
POSTGRESADMIN_EMAIL=admin@example.com
POSTGRESADMIN_PASSWORD=adminpass
